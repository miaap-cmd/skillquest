# COPILOT_API_KEY: Required for Copilot AI API calls.
# Configure this in your environment or deployment settings.
COPILOT_API_KEY="MY_COPILOT_API_KEY"

# COPILOT_MODEL: Optional model identifier to use for Copilot requests.
COPILOT_MODEL="copilot-default"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
